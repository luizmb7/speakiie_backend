    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.13.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
