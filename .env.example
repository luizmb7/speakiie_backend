# ──────────────────────────────────────────
# Speakiie Backend — Variáveis de Ambiente
# ──────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.

# ── Banco de dados ──
DATABASE_URL=postgres://speakiie:speakiie_dev@localhost:5432/speakiie

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_SECRET=troque-por-uma-chave-segura-de-pelo-menos-32-caracteres
JWT_EXPIRES_IN=90d
JWT_REFRESH_EXPIRES_IN=180d

# ── LiveKit ──
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-deve-ter-pelo-menos-32-caracteres
LIVEKIT_WS_URL=ws://localhost:7880

# ── Servidor ──
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ── Housekeeping ──
GUEST_EXPIRY_DAYS=90
